{
  "name": "@template/backend",
  "version": "0.1.0-beta.7",
  "private": true,
  "type": "module",
  "main": "convex/_generated/api.js",
  "types": "convex/_generated/api.d.ts",
  "exports": {
    ".": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    }
  },
  "scripts": {
    "dev": "convex dev",
    "build": "convex codegen",
    "deploy": "convex deploy",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "seed": "convex run seed:seed",
    "seed:clear": "convex run seed:clear",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "convex": "^1.24.8",
    "express": "^5.1.0",
    "node-fetch": "^3.3.2",
    "svix": "^1.69.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@clerk/backend": "^2.0.0",
    "@template/types": "workspace:^",
    "svix": "^1.69.0",
    "convex-test": "^0.0.37"
  }
}
