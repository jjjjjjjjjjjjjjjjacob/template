# Convex Database URL
# Get this from your Convex dashboard after setting up your project
VITE_CONVEX_URL=your_convex_deployment_url
CONVEX_DEPLOYMENT=your_convex_deployment_name

# Clerk Authentication - Required for auth.config.js
# This should match your Clerk instance domain (e.g., https://your-app.clerk.accounts.dev)
CLERK_FRONTEND_API_URL=your_clerk_frontend_api_url

# Admin allowlist (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Scheduling / Google Calendar
# These are Convex server-side env vars. Do not expose them with VITE_.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3030/admin/scheduling/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_ALLOWED_ACCOUNT_EMAIL=jacob@jacobstein.me
GOOGLE_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret
BOOKING_PUBLIC_BASE_URL=http://localhost:3030/

# Booking owner notifications
# Resend is used server-side from Convex. Do not expose these with VITE_.
RESEND_API_KEY=your_resend_api_key
BOOKING_NOTIFICATION_FROM="Jacob Stein <notifications@jacobstein.me>"
BOOKING_NOTIFICATION_TO=jacob@jacobstein.me
