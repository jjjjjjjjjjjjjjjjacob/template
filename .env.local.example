# PostHog Analytics Configuration
# Sign up at https://posthog.com and get these values from your project settings
VITE_POSTHOG_API_KEY=your_posthog_api_key
VITE_POSTHOG_API_HOST=https://app.posthog.com
VITE_POSTHOG_PROJECT_ID=your_project_id
VITE_POSTHOG_REGION=us

# Clerk Authentication (if using Clerk for auth)
# Get these from your Clerk dashboard: https://clerk.com
# Note: These may be needed for server-side operations
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_FRONTEND_API_URL=your_clerk_frontend_api_url
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_webhook_secret

# Convex Database URL
VITE_CONVEX_URL=your_convex_deployment_url
CONVEX_DEPLOYMENT=your_convex_deployment_name

# Scheduling / Google Calendar
# Enable Google Calendar API and create OAuth Web Application credentials.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3030/admin/scheduling/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_ALLOWED_ACCOUNT_EMAIL=jacob@jacobstein.me
GOOGLE_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret
BOOKING_PUBLIC_BASE_URL=http://localhost:3030/
