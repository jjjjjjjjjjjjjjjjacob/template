{
  "name": "template",
  "version": "0.1.0-beta.7",
  "private": true,
  "packageManager": "bun@1.2.16",
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@template/web --filter=@template/backend",
    "dev:frontend": "turbo run dev --filter=@template/web",
    "dev:backend": "turbo run dev --filter=@template/backend",
    "dev:webhooks": "bunx svix listen https://127.0.0.1:3210/webhooks/clerk",
    "seed": "turbo run seed --filter=@template/backend",
    "seed:clear": "turbo run seed:clear --filter=@template/backend",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --filter=@template/web",
    "test:integration": "turbo run test:integration --filter=@template/web",
    "test:integration:watch": "turbo run test:integration:watch --filter=@template/web",
    "test:coverage": "turbo run test:coverage",
    "test:all": "bun run test && bun run test:integration",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "lint:fix": "turbo run lint:fix",
    "format:check": "prettier --check .",
    "format:staged": "prettier --write --cache --ignore-unknown",
    "typecheck": "turbo run typecheck",
    "quality": "bun run typecheck && bun run test && bun run format:check && bun run lint",
    "quality:fix": "bun run typecheck && bun run lint:fix && bun run format",
    "deploy": "turbo run deploy --filter=@template/web",
    "cf-typegen": "turbo run cf-typegen --filter=@template/web",
    "clean": "turbo run clean && rm -rf .turbo",
    "sync:tags": "bun run scripts/sync-tags.ts",
    "sync:tags:export": "./scripts/export-dev-tags.sh",
    "sync:tags:seed": "./scripts/seed-prod-tags.sh",
    "sync:tags:all": "./scripts/sync-tags-to-prod.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@happy-dom/global-registrator": "^17.5.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.15",
    "@types/react-window": "^1.8.8",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "convex": "^1.25.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsup": "^8.5.0",
    "turbo": "^2.10.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "jspdf": "^3.0.2"
  },
  "overrides": {
    "rollup": "^4.45.1"
  }
}
