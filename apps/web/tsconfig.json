{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./src/*"],
      "@template/backend": ["../../packages/backend"],
      "@template/backend/*": ["../../packages/backend/*"],
      "@template/scheduler": ["../../packages/scheduler/src/index.ts"],
      "@template/scheduler/*": ["../../packages/scheduler/src/*"],
      "@template/types": ["../../packages/types/src/index.ts"],
      "@template/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/backend/convex/_generated/api.d.ts",
    "../../packages/backend/convex/_generated/dataModel.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".output",
    "**/*.test.ts",
    "**/*.test.tsx",
    "vite.config.ts"
  ]
}
